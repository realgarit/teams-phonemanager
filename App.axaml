<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:teams_phonemanager"
             xmlns:converters="clr-namespace:teams_phonemanager.Converters"
             xmlns:fa="using:FluentAvalonia.Styling"
             xmlns:fi="using:FluentIcons.Avalonia"
             x:Class="teams_phonemanager.App"
             RequestedThemeVariant="Dark">
    <Application.DataTemplates>
        <!-- VM-first view resolution (replaces the per-View service-locator). -->
        <local:ViewLocator/>
    </Application.DataTemplates>
    <Application.Resources>
        <ResourceDictionary>
            <!-- Value Converters -->
            <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>

            <!-- Typography assets -->
            <FontFamily x:Key="DisplayFontFamily">avares://teams-phonemanager/Resources/Fonts#Sora</FontFamily>
            <FontFamily x:Key="CodeFontFamily">avares://teams-phonemanager/Resources/Fonts#JetBrains Mono</FontFamily>

            <!-- Softer default corner radii for inputs and flyouts -->
            <CornerRadius x:Key="ControlCornerRadius">8</CornerRadius>
            <CornerRadius x:Key="OverlayCornerRadius">12</CornerRadius>

            <ResourceDictionary.ThemeDictionaries>
                <!-- ════════ DARK: deep ink-violet console ════════ -->
                <ResourceDictionary x:Key="Dark">
                    <!-- Teams Violet accent (legacy keys kept for existing views) -->
                    <SolidColorBrush x:Key="TeamsPrimaryBrush" Color="#8B92F2"/>
                    <SolidColorBrush x:Key="TeamsPrimaryLightBrush" Color="#ADB2F7"/>
                    <SolidColorBrush x:Key="TeamsPrimaryDarkBrush" Color="#464775"/>

                    <!-- App surfaces -->
                    <LinearGradientBrush x:Key="AppBackgroundBrush" StartPoint="0%,0%" EndPoint="100%,100%">
                        <GradientStop Offset="0" Color="#191831"/>
                        <GradientStop Offset="0.45" Color="#141322"/>
                        <GradientStop Offset="1" Color="#11101B"/>
                    </LinearGradientBrush>
                    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#99151424"/>
                    <SolidColorBrush x:Key="SurfaceCardBrush" Color="#CC1D1C30"/>
                    <SolidColorBrush x:Key="SurfaceCardHoverBrush" Color="#242238"/>
                    <SolidColorBrush x:Key="SurfaceSunkenBrush" Color="#14131F"/>
                    <SolidColorBrush x:Key="SurfaceDialogBrush" Color="#201F33"/>
                    <SolidColorBrush x:Key="HairlineBrush" Color="#2C2B44"/>
                    <SolidColorBrush x:Key="AccentHairlineBrush" Color="#4A4B7A"/>
                    <SolidColorBrush x:Key="AccentSoftBrush" Color="#2E7B83EB"/>
                    <SolidColorBrush x:Key="SuccessSoftBrush" Color="#1F3FB68B"/>
                    <SolidColorBrush x:Key="SuccessHairlineBrush" Color="#403FB68B"/>
                    <SolidColorBrush x:Key="StatusOnBrush" Color="#4ADE80"/>
                    <SolidColorBrush x:Key="StatusOffBrush" Color="#55556A"/>
                    <!-- Brand mark gradient -->
                    <LinearGradientBrush x:Key="BrandGradientBrush" StartPoint="0%,0%" EndPoint="100%,100%">
                        <GradientStop Offset="0" Color="#7B83EB"/>
                        <GradientStop Offset="1" Color="#4B4D9E"/>
                    </LinearGradientBrush>
                </ResourceDictionary>

                <!-- ════════ LIGHT: violet-tinted paper ════════ -->
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="TeamsPrimaryBrush" Color="#5B5FC7"/>
                    <SolidColorBrush x:Key="TeamsPrimaryLightBrush" Color="#8B8FC7"/>
                    <SolidColorBrush x:Key="TeamsPrimaryDarkBrush" Color="#444791"/>

                    <LinearGradientBrush x:Key="AppBackgroundBrush" StartPoint="0%,0%" EndPoint="100%,100%">
                        <GradientStop Offset="0" Color="#F4F2FC"/>
                        <GradientStop Offset="1" Color="#EDECF6"/>
                    </LinearGradientBrush>
                    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#80EAE8F5"/>
                    <SolidColorBrush x:Key="SurfaceCardBrush" Color="#F2FFFFFF"/>
                    <SolidColorBrush x:Key="SurfaceCardHoverBrush" Color="#FFFFFF"/>
                    <SolidColorBrush x:Key="SurfaceSunkenBrush" Color="#F1F0F8"/>
                    <SolidColorBrush x:Key="SurfaceDialogBrush" Color="#FCFBFF"/>
                    <SolidColorBrush x:Key="HairlineBrush" Color="#E0DEEE"/>
                    <SolidColorBrush x:Key="AccentHairlineBrush" Color="#B9BCEC"/>
                    <SolidColorBrush x:Key="AccentSoftBrush" Color="#225B5FC7"/>
                    <SolidColorBrush x:Key="SuccessSoftBrush" Color="#1F1E9E6A"/>
                    <SolidColorBrush x:Key="SuccessHairlineBrush" Color="#401E9E6A"/>
                    <SolidColorBrush x:Key="StatusOnBrush" Color="#16A34A"/>
                    <SolidColorBrush x:Key="StatusOffBrush" Color="#A6A4BC"/>
                    <LinearGradientBrush x:Key="BrandGradientBrush" StartPoint="0%,0%" EndPoint="100%,100%">
                        <GradientStop Offset="0" Color="#6A6FDD"/>
                        <GradientStop Offset="1" Color="#4B4D9E"/>
                    </LinearGradientBrush>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
    <Application.Styles>
        <fa:FluentAvaloniaTheme CustomAccentColor="#5B5FC7" />
        <!-- Global Control Styles -->
        <Style Selector="TextBox">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="ComboBox /template/ ContentPresenter#ContentPresenter">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="CalendarDatePicker">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="NumericUpDown">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- ════════════════════════════════════════════════
             Surfaces: card / sunken / dialog
             ════════════════════════════════════════════════ -->
        <Style Selector="Border.card">
            <Setter Property="Background" Value="{DynamicResource SurfaceCardBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="BoxShadow" Value="0 1 3 0 #14000000"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
        <!-- Card that reacts to hover (use for step / action cards) -->
        <Style Selector="Border.card.interactive:pointerover">
            <Setter Property="Background" Value="{DynamicResource SurfaceCardHoverBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentHairlineBrush}"/>
        </Style>
        <!-- Sunken surface for code / log output areas -->
        <Style Selector="Border.sunken">
            <Setter Property="Background" Value="{DynamicResource SurfaceSunkenBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
        </Style>
        <Style Selector="Border.dialog">
            <Setter Property="Background" Value="{DynamicResource SurfaceDialogBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="BoxShadow" Value="0 12 40 0 #59000000"/>
        </Style>

        <!-- Accent icon badge used in page headers -->
        <Style Selector="Border.icon-badge">
            <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Border.icon-badge fi|SymbolIcon">
            <Setter Property="IsFilled" Value="True"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource TeamsPrimaryBrush}"/>
        </Style>

        <!-- Status chips (pill with dot), used for connection state -->
        <Style Selector="Border.chip">
            <Setter Property="CornerRadius" Value="99"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceSunkenBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="Border.chip.ok">
            <Setter Property="Background" Value="{DynamicResource SuccessSoftBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SuccessHairlineBrush}"/>
        </Style>
        <Style Selector="Border.chip TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Ellipse.status-dot">
            <Setter Property="Width" Value="7"/>
            <Setter Property="Height" Value="7"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Reusable Button Styles for Icon+Text patterns -->
        <Style Selector="Button.IconText">
            <Setter Property="Height" Value="40"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="Button.IconTextLarge">
            <Setter Property="Height" Value="50"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="CornerRadius" Value="10"/>
        </Style>
        <!-- Centered Icon+Text Button (for Welcome page) -->
        <Style Selector="Button.IconTextCentered">
            <Setter Property="Height" Value="50"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="CornerRadius" Value="10"/>
        </Style>
        <!-- Icon Only Button (for Settings, etc.) -->
        <Style Selector="Button.IconOnly">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <!--
            Icon styles - Cross-platform vertical centering fix

            FluentIcons SymbolIcon renders as font glyphs. Font metrics (baseline, ascent, descent)
            cause visual misalignment across platforms because Avalonia centers mathematically
            rather than visually (known issue: https://github.com/AvaloniaUI/Avalonia/issues/10658).

            The fix: Use UseLayoutRounding and proper alignment. Do not set fixed Width/Height
            as icons may have custom FontSize values that need to scale naturally.
        -->

        <!-- Default: Standard icon styling -->
        <Style Selector="fi|SymbolIcon">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="UseLayoutRounding" Value="True"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <!-- Ensure icons inherit theme foreground in all common containers -->
        <Style Selector="ListBoxItem fi|SymbolIcon">
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
        <Style Selector="Button fi|SymbolIcon">
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
        </Style>
        <Style Selector="StackPanel fi|SymbolIcon">
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
        </Style>

        <!-- Accent button: white text/icons on Teams violet background -->
        <Style Selector="Button.accent fi|SymbolIcon">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.accent TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- IconOnly override: No margin (centered in button) -->
        <Style Selector="Button.IconOnly fi|SymbolIcon">
            <Setter Property="Margin" Value="0"/>
        </Style>

        <!-- ════════════════════════════════════════════════
             Sidebar navigation ListBox / ListBoxItem styles
             ════════════════════════════════════════════════ -->
        <Style Selector="ListBox.nav">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0,4"/>
        </Style>
        <Style Selector="ListBox.nav ListBoxItem">
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="ListBox.nav ListBoxItem TextBlock">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Foreground" Duration="0:0:0.12"/>
                </Transitions>
            </Setter>
        </Style>
        <!-- Filled nav icons: solid glyphs avoid uneven stroke rendering at 16px -->
        <Style Selector="ListBox.nav ListBoxItem fi|SymbolIcon">
            <Setter Property="IsFilled" Value="True"/>
        </Style>
        <Style Selector="ListBox.nav ListBoxItem /template/ ContentPresenter">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.12"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="ListBox.nav ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}"/>
        </Style>
        <Style Selector="ListBox.nav ListBoxItem:selected TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TeamsPrimaryBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="ListBox.nav ListBoxItem:selected fi|SymbolIcon">
            <Setter Property="Foreground" Value="{DynamicResource TeamsPrimaryBrush}"/>
        </Style>
        <Style Selector="ListBox.nav ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
        </Style>
        <!-- Non-selectable section label rows inside the nav list -->
        <Style Selector="ListBox.nav ListBoxItem.nav-header">
            <Setter Property="Padding" Value="12,14,12,4"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
        <Style Selector="ListBox.nav ListBoxItem.nav-header TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="LetterSpacing" Value="1.4"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}"/>
        </Style>

        <!-- ════════════════════════════════════
             Typography: page-title / section-title / hint
             ════════════════════════════════════ -->
        <!-- Large page title — use with TextBlock Classes="page-title" -->
        <Style Selector="TextBlock.page-title">
            <Setter Property="FontSize" Value="26"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="{StaticResource DisplayFontFamily}"/>
            <Setter Property="LetterSpacing" Value="-0.3"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <!-- Section sub-heading — use with TextBlock Classes="section-title" -->
        <Style Selector="TextBlock.section-title">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <!-- Small helper / hint text — use with TextBlock Classes="hint" -->
        <Style Selector="TextBlock.hint">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Opacity" Value="0.6"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
        <!-- Dialog heading — use with TextBlock Classes="dialog-title" -->
        <Style Selector="TextBlock.dialog-title">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="{StaticResource DisplayFontFamily}"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
        <!-- Monospace code/log text — use with TextBox/TextBlock Classes="code" -->
        <Style Selector="TextBox.code">
            <Setter Property="FontFamily" Value="{StaticResource CodeFontFamily}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style Selector="TextBlock.code">
            <Setter Property="FontFamily" Value="{StaticResource CodeFontFamily}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Application.Styles>
</Application>