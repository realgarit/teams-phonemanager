<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="using:FluentAvalonia.UI.Controls"
        xmlns:fi="using:FluentIcons.Avalonia"
        xmlns:fic="using:FluentIcons.Common"
        xmlns:local="clr-namespace:teams_phonemanager"
        xmlns:viewmodels="clr-namespace:teams_phonemanager.ViewModels"
        xmlns:converters="clr-namespace:teams_phonemanager.Converters"
        xmlns:views="clr-namespace:teams_phonemanager.Views"
        xmlns:services="clr-namespace:teams_phonemanager.Services"
        mc:Ignorable="d"
        x:Class="teams_phonemanager.MainWindow"
        Title="Teams Phone Manager"
        Icon="avares://TeamsPhoneManager.Presentation/Resources/app-icon.png"
        Width="1280"
        Height="720"
        MinWidth="1024"
        MinHeight="640"
        Background="{DynamicResource AppBackgroundBrush}">

    <!-- DataContext is set via DI in App.xaml.cs -->

    <Grid x:Name="MainGrid">

        <!-- ════════ Main layout: sidebar + content ════════ -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="244"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0"
                    Background="{DynamicResource SidebarBackgroundBrush}"
                    BorderBrush="{DynamicResource HairlineBrush}"
                    BorderThickness="0,0,1,0">
                <Grid RowDefinitions="Auto,*,Auto">

                    <!-- Brand block -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="16,18,16,10">
                        <Border Width="38" Height="38"
                                CornerRadius="11"
                                Background="{DynamicResource BrandGradientBrush}"
                                BoxShadow="0 4 14 0 #405B5FC7">
                            <fi:SymbolIcon Symbol="Call"
                                           IsFilled="True"
                                           FontSize="19"
                                           Foreground="White"
                                           Margin="0"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center" Spacing="1">
                            <TextBlock Text="Teams Phone"
                                       FontFamily="{StaticResource DisplayFontFamily}"
                                       FontSize="15"
                                       FontWeight="Bold"
                                       LetterSpacing="-0.2"/>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="Manager"
                                           FontFamily="{StaticResource DisplayFontFamily}"
                                           FontSize="11"
                                           Foreground="{DynamicResource TeamsPrimaryBrush}"
                                           LetterSpacing="2.2"/>
                                <TextBlock Text="{Binding Version}"
                                           FontSize="10"
                                           VerticalAlignment="Center"
                                           Opacity="0.45"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- Navigation -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ListBox x:Name="NavigationListBox" Classes="nav" Margin="10,0"
                                 SelectionChanged="NavigationListBox_SelectionChanged">

                            <ListBoxItem Classes="nav-header" IsEnabled="False" Focusable="False">
                                <TextBlock Text="OVERVIEW"/>
                            </ListBoxItem>

                            <ListBoxItem Tag="Welcome" Classes="nav" AutomationProperties.Name="Welcome">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
                                    <fi:SymbolIcon Symbol="Home"/>
                                    <TextBlock Text="Welcome" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </ListBoxItem>

                            <ListBoxItem Tag="GetStarted" Classes="nav" AutomationProperties.Name="Get Started">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
                                    <fi:SymbolIcon Symbol="Rocket"/>
                                    <TextBlock Text="Get Started" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </ListBoxItem>

                            <ListBoxItem Tag="Variables" Classes="nav" AutomationProperties.Name="Variables">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
                                    <fi:SymbolIcon Symbol="Code"/>
                                    <TextBlock Text="Variables" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </ListBoxItem>

                            <ListBoxItem Classes="nav-header" IsEnabled="False" Focusable="False">
                                <TextBlock Text="PROVISIONING"/>
                            </ListBoxItem>

                            <ListBoxItem Tag="M365Groups" Classes="nav" AutomationProperties.Name="M365 Groups">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
                                    <fi:SymbolIcon Symbol="People"/>
                                    <TextBlock Text="M365 Groups" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </ListBoxItem>

                            <ListBoxItem Tag="CallQueues" Classes="nav" AutomationProperties.Name="Call Queues">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
                                    <fi:SymbolIcon Symbol="CallInbound"/>
                                    <TextBlock Text="Call Queues" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </ListBoxItem>

                            <ListBoxItem Tag="AutoAttendants" Classes="nav" AutomationProperties.Name="Auto Attendants">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
                                    <fi:SymbolIcon Symbol="Bot"/>
                                    <TextBlock Text="Auto Attendants" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </ListBoxItem>

                            <ListBoxItem Tag="Holidays" Classes="nav" AutomationProperties.Name="Holidays">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
                                    <fi:SymbolIcon Symbol="Calendar"/>
                                    <TextBlock Text="Holidays" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </ListBoxItem>

                            <ListBoxItem Classes="nav-header" IsEnabled="False" Focusable="False">
                                <TextBlock Text="TOOLS"/>
                            </ListBoxItem>

                            <ListBoxItem Tag="Wizard" Classes="nav" AutomationProperties.Name="Setup Wizard">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
                                    <fi:SymbolIcon Symbol="Wand"/>
                                    <TextBlock Text="Setup Wizard" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </ListBoxItem>

                            <ListBoxItem Tag="BulkOperations" Classes="nav" AutomationProperties.Name="Bulk Operations">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
                                    <fi:SymbolIcon Symbol="TableMultiple"/>
                                    <TextBlock Text="Bulk Operations" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </ListBoxItem>

                            <ListBoxItem Tag="Documentation" Classes="nav" AutomationProperties.Name="Documentation">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
                                    <fi:SymbolIcon Symbol="DocumentText"/>
                                    <TextBlock Text="Documentation" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </ListBoxItem>
                        </ListBox>
                    </ScrollViewer>

                    <!-- Sidebar footer: connection state + settings -->
                    <StackPanel Grid.Row="2" Margin="16,10,16,14" Spacing="10">
                        <Border Height="1" Background="{DynamicResource HairlineBrush}" Margin="-6,0"/>
                        <Grid ColumnDefinitions="*,Auto" ToolTip.Tip="{Binding ConnectionStatusText}">
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                                <Border Classes="chip" Classes.ok="{Binding IsTeamsConnected}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Ellipse Classes="status-dot" Fill="{DynamicResource StatusOnBrush}"
                                                 IsVisible="{Binding IsTeamsConnected}"/>
                                        <Ellipse Classes="status-dot" Fill="{DynamicResource StatusOffBrush}"
                                                 IsVisible="{Binding !IsTeamsConnected}"/>
                                        <TextBlock Text="Teams"/>
                                    </StackPanel>
                                </Border>
                                <Border Classes="chip" Classes.ok="{Binding IsGraphConnected}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Ellipse Classes="status-dot" Fill="{DynamicResource StatusOnBrush}"
                                                 IsVisible="{Binding IsGraphConnected}"/>
                                        <Ellipse Classes="status-dot" Fill="{DynamicResource StatusOffBrush}"
                                                 IsVisible="{Binding !IsGraphConnected}"/>
                                        <TextBlock Text="Graph"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            <Button x:Name="SettingsButton"
                                    Grid.Column="1"
                                    Command="{Binding ToggleSettingsCommand}"
                                    Width="34"
                                    Height="34"
                                    Classes="IconOnly"
                                    AutomationProperties.Name="Settings"
                                    ToolTip.Tip="Settings">
                                <fi:SymbolIcon Symbol="Settings"/>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content column -->
            <Grid Grid.Column="1" RowDefinitions="*,Auto">

                <!-- Content Area -->
                <Grid Grid.Row="0" Margin="20,18,20,10">
                    <TransitioningContentControl Content="{Binding CurrentViewModel}">
                        <TransitioningContentControl.PageTransition>
                            <CrossFade Duration="0:0:0.15"/>
                        </TransitioningContentControl.PageTransition>
                    </TransitioningContentControl>
                </Grid>

                <!-- Status Bar -->
                <Border Grid.Row="1"
                        Background="Transparent"
                        BorderBrush="{DynamicResource HairlineBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="20,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Latest Log Entry - Clickable Log Area -->
                        <Button Grid.Column="0"
                                Command="{Binding ToggleLogDialogCommand}"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="8,5"
                                CornerRadius="8"
                                HorizontalAlignment="Stretch"
                                ToolTip.Tip="Click to view full log"
                                AutomationProperties.Name="Latest Log Entry. Click to view full log.">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <fi:SymbolIcon Grid.Column="0"
                                          FontSize="14"
                                          Symbol="Code"
                                          Foreground="{DynamicResource TeamsPrimaryBrush}"
                                          VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                         Text="{Binding LatestLogEntry}"
                                         TextTrimming="CharacterEllipsis"
                                         VerticalAlignment="Center"
                                         Classes="code"
                                         FontSize="11"
                                         Opacity="0.85"/>
                                <fi:SymbolIcon Grid.Column="2"
                                          FontSize="13"
                                          Symbol="ChevronRight"
                                          Margin="8,0,0,0"
                                          Opacity="0.5"
                                          VerticalAlignment="Center"/>
                            </Grid>
                        </Button>

                        <!-- Copyright -->
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Copyright}"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Margin="16,0,0,0"
                                   Opacity="0.5"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Log Viewer Dialog - Border overlay -->
        <Border IsVisible="{Binding IsLogDialogOpen}"
                Background="#8C0A0A14"
                ZIndex="1000"
                PointerPressed="LogDialogBackdrop_PointerPressed">
            <Border.Styles>
                <Style Selector="Border">
                    <Style.Animations>
                        <Animation Duration="0:0:0.2">
                            <KeyFrame Cue="0%">
                                <Setter Property="Opacity" Value="0"/>
                            </KeyFrame>
                            <KeyFrame Cue="100%">
                                <Setter Property="Opacity" Value="1"/>
                            </KeyFrame>
                        </Animation>
                    </Style.Animations>
                </Style>
            </Border.Styles>
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center"
                  PointerPressed="LogDialogCard_PointerPressed">
                <Border Classes="dialog"
                        Margin="16" MaxWidth="1000" MaxHeight="600" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <!-- Dialog Header -->
                        <Border Grid.Row="0"
                                BorderBrush="{DynamicResource HairlineBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="20,12">
                            <DockPanel LastChildFill="False">
                                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                    <fi:SymbolIcon Symbol="Code" Foreground="{DynamicResource TeamsPrimaryBrush}"/>
                                    <TextBlock Text="Log Viewer"
                                             FontFamily="{StaticResource DisplayFontFamily}"
                                             FontWeight="SemiBold"
                                             VerticalAlignment="Center"/>
                                </StackPanel>
                                <Button DockPanel.Dock="Right"
                                        Command="{Binding CloseLogDialogCommand}"
                                        Width="36"
                                        Height="36"
                                        Classes="IconOnly"
                                        AutomationProperties.Name="Close Log Viewer"
                                        ToolTip.Tip="Close">
                                    <fi:SymbolIcon Symbol="Dismiss"/>
                                </Button>
                            </DockPanel>
                        </Border>
                        <!-- Log Content -->
                        <Border Grid.Row="1" Classes="sunken" Margin="16">
                            <ScrollViewer x:Name="LogScrollViewer"
                                        VerticalScrollBarVisibility="Auto"
                                        HorizontalScrollBarVisibility="Auto">
                                <TextBox x:Name="LogView"
                                       Text="{Binding AllLogEntriesText, Mode=OneWay}"
                                       TextWrapping="NoWrap"
                                       Classes="code"
                                       IsReadOnly="True"
                                       AcceptsReturn="True"
                                       AcceptsTab="True"
                                       BorderThickness="0"
                                       Background="Transparent"
                                       Padding="12"
                                       VerticalContentAlignment="Top"
                                       TextChanged="LogView_TextChanged">
                                    <TextBox.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Clear Log"
                                                    Command="{Binding ClearLogCommand}"/>
                                        </ContextMenu>
                                    </TextBox.ContextMenu>
                                </TextBox>
                            </ScrollViewer>
                        </Border>
                        <!-- Dialog Footer -->
                        <StackPanel Grid.Row="2"
                                   Orientation="Horizontal"
                                   HorizontalAlignment="Right"
                                   Margin="16,0,16,16"
                                   Spacing="12">
                            <Button Command="{Binding ClearLogCommand}"
                                    Classes="IconText">
                                <StackPanel Orientation="Horizontal">
                                    <fi:SymbolIcon FontSize="16" Symbol="Delete"/>
                                    <TextBlock Text="Clear Log" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding CloseLogDialogCommand}"
                                    Classes="IconText">
                                <StackPanel Orientation="Horizontal">
                                    <fi:SymbolIcon FontSize="16" Symbol="Dismiss"/>
                                    <TextBlock Text="Close" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Settings Side Panel -->
        <!-- Overlay backdrop -->
        <Border Background="#8C0A0A14"
                IsVisible="{Binding IsSettingsOpen}"
                ZIndex="1000"
                PointerPressed="SettingsOverlay_PointerPressed">
            <Border.Styles>
                <Style Selector="Border">
                    <Style.Animations>
                        <Animation Duration="0:0:0.2">
                            <KeyFrame Cue="0%">
                                <Setter Property="Opacity" Value="0"/>
                            </KeyFrame>
                            <KeyFrame Cue="100%">
                                <Setter Property="Opacity" Value="1"/>
                            </KeyFrame>
                        </Animation>
                    </Style.Animations>
                </Style>
            </Border.Styles>
        </Border>
        <!-- Side panel -->
        <Border Background="{DynamicResource SurfaceDialogBrush}"
                Width="400"
                HorizontalAlignment="Right"
                VerticalAlignment="Stretch"
                IsVisible="{Binding IsSettingsOpen}"
                ZIndex="1001"
                ClipToBounds="True"
                BorderBrush="{DynamicResource HairlineBrush}"
                BorderThickness="1,0,0,0"
                BoxShadow="-8 0 32 0 #50000000">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <!-- Header -->
                <Border Grid.Row="0"
                        BorderBrush="{DynamicResource HairlineBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="24,16">
                    <DockPanel LastChildFill="False">
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <fi:SymbolIcon Symbol="Settings" Foreground="{DynamicResource TeamsPrimaryBrush}"/>
                            <TextBlock Text="Settings"
                                     FontFamily="{StaticResource DisplayFontFamily}"
                                     FontSize="17"
                                     FontWeight="SemiBold"
                                     VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button DockPanel.Dock="Right"
                                Command="{Binding CloseSettingsCommand}"
                                Width="36"
                                Height="36"
                                Classes="IconOnly"
                                AutomationProperties.Name="Close Settings"
                                ToolTip.Tip="Close">
                            <fi:SymbolIcon Symbol="Dismiss"/>
                        </Button>
                    </DockPanel>
                </Border>
                <!-- Content -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24,20" Spacing="20">

                        <!-- Appearance Section -->
                        <StackPanel Spacing="12">
                            <TextBlock Text="Appearance"
                                     FontSize="16"
                                     FontWeight="SemiBold"/>

                            <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                                <TextBlock Grid.Column="0"
                                         Text="Dark Theme"
                                         VerticalAlignment="Center"/>
                                <ToggleSwitch Grid.Column="1"
                                            IsChecked="{Binding IsDarkTheme}"
                                            Margin="12,0,0,0"
                                            VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>

                        <Border Height="1" Background="{DynamicResource HairlineBrush}"/>

                        <!-- Workflow Section -->
                        <StackPanel Spacing="12">
                            <TextBlock Text="Workflow"
                                     FontSize="16"
                                     FontWeight="SemiBold"/>

                            <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Skip Script Preview"/>
                                    <TextBlock Text="Execute without showing the preview dialog"
                                             FontSize="11" Opacity="0.6" TextWrapping="Wrap"/>
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1"
                                            IsChecked="{Binding SkipScriptPreview}"
                                            Margin="12,0,0,0"
                                            VerticalAlignment="Center"/>
                            </Grid>

                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Skip Delete Confirmation"/>
                                    <TextBlock Text="Remove items without a confirmation dialog"
                                             FontSize="11" Opacity="0.6" TextWrapping="Wrap"/>
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1"
                                            IsChecked="{Binding SkipDeleteConfirmation}"
                                            Margin="12,0,0,0"
                                            VerticalAlignment="Center"/>
                            </Grid>

                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Auto-Refresh After Operations"/>
                                    <TextBlock Text="Reload lists after creating or removing items"
                                             FontSize="11" Opacity="0.6" TextWrapping="Wrap"/>
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1"
                                            IsChecked="{Binding AutoRefreshAfterOperations}"
                                            Margin="12,0,0,0"
                                            VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>

                        <Border Height="1" Background="{DynamicResource HairlineBrush}"/>

                        <!-- Logging Section -->
                        <StackPanel Spacing="12">
                            <TextBlock Text="Logging"
                                     FontSize="16"
                                     FontWeight="SemiBold"/>

                            <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Minimum Log Level"/>
                                    <TextBlock Text="Filter entries shown in the log viewer"
                                             FontSize="11" Opacity="0.6" TextWrapping="Wrap"/>
                                </StackPanel>
                                <ComboBox Grid.Column="1"
                                        SelectedIndex="{Binding SelectedLogLevelIndex}"
                                        MinWidth="110"
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center">
                                    <ComboBoxItem Content="Info"/>
                                    <ComboBoxItem Content="Success"/>
                                    <ComboBoxItem Content="Warning"/>
                                    <ComboBoxItem Content="Error"/>
                                </ComboBox>
                            </Grid>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Update notification banner (top overlay, dismissible) -->
        <ui:InfoBar Grid.Column="0" Grid.ColumnSpan="2"
                    Title="Update available"
                    Message="{Binding UpdateBannerMessage}"
                    IsOpen="{Binding IsUpdateBannerVisible, Mode=TwoWay}"
                    Severity="Informational"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Center"
                    MinWidth="420"
                    Margin="0,8,0,0">
            <ui:InfoBar.ActionButton>
                <Button Content="View release" Command="{Binding OpenUpdatePageCommand}"/>
            </ui:InfoBar.ActionButton>
        </ui:InfoBar>
    </Grid>
</Window>