<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:fi="using:FluentIcons.Avalonia"
             xmlns:fic="using:FluentIcons.Common"
             xmlns:local="clr-namespace:teams_phonemanager.Views"
             xmlns:viewmodels="clr-namespace:teams_phonemanager.ViewModels"
             x:Class="teams_phonemanager.Views.WelcomeView"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1000">

    <UserControl.Styles>
        <!-- Staggered entrance for hero elements -->
        <Style Selector="StackPanel.hero">
            <Style.Animations>
                <Animation Duration="0:0:0.45" Easing="CubicEaseOut">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="0"/>
                        <Setter Property="TranslateTransform.Y" Value="14"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="1"/>
                        <Setter Property="TranslateTransform.Y" Value="0"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="Grid.workflow">
            <Style.Animations>
                <Animation Duration="0:0:0.6" Easing="CubicEaseOut">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="0"/>
                        <Setter Property="TranslateTransform.Y" Value="18"/>
                    </KeyFrame>
                    <KeyFrame Cue="40%">
                        <Setter Property="Opacity" Value="0"/>
                        <Setter Property="TranslateTransform.Y" Value="18"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="1"/>
                        <Setter Property="TranslateTransform.Y" Value="0"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <!-- Step number badge -->
        <Style Selector="Border.step-badge">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="CornerRadius" Value="9"/>
            <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}"/>
        </Style>
        <Style Selector="Border.step-badge TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource DisplayFontFamily}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TeamsPrimaryBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="24" VerticalAlignment="Center" MaxWidth="980">

            <!-- Hero -->
            <StackPanel Classes="hero" HorizontalAlignment="Center" Margin="0,16,0,36">
                <Border Width="76" Height="76"
                        CornerRadius="17"
                        HorizontalAlignment="Center"
                        BoxShadow="0 10 36 0 #555B5FC7"
                        Margin="0,0,0,22">
                    <!-- The actual app icon, so branding matches the dock/taskbar/installer.
                         CornerRadius mirrors the icon's own corner radius (76 * 230/1024). -->
                    <Image Source="avares://TeamsPhoneManager.Presentation/Resources/app-icon.png"
                           Width="76" Height="76"/>
                </Border>
                <TextBlock Text="Teams Phone Manager"
                         FontFamily="{StaticResource DisplayFontFamily}"
                         FontSize="36"
                         FontWeight="Bold"
                         LetterSpacing="-0.8"
                         TextAlignment="Center"/>
                <TextBlock Text="Configure and deploy Microsoft Teams Phone infrastructure"
                         FontSize="15"
                         TextAlignment="Center"
                         Margin="0,10,0,0"
                         Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

                <!-- Quick Actions -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12" Margin="0,28,0,0">
                    <Button Command="{Binding NavigateToGetStartedCommand}"
                            Classes="accent IconTextCentered" MinWidth="180">
                        <StackPanel Orientation="Horizontal">
                            <fi:SymbolIcon Symbol="Rocket"/>
                            <TextBlock Text="Get Started"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding OpenDocumentationCommand}"
                            Classes="IconTextCentered" MinWidth="180">
                        <StackPanel Orientation="Horizontal">
                            <fi:SymbolIcon Symbol="Open"/>
                            <TextBlock Text="GitHub"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>

            <!-- Workflow Steps -->
            <Grid Classes="workflow">
                <StackPanel>
                    <TextBlock Text="HOW IT WORKS"
                               FontSize="11"
                               FontWeight="SemiBold"
                               LetterSpacing="2"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,14"/>
                    <Grid ColumnDefinitions="*,Auto,*,Auto,*,Auto,*">
                        <!-- Step 1 -->
                        <Border Grid.Column="0" Classes="card interactive" Padding="16">
                            <StackPanel Spacing="10">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Border Classes="step-badge">
                                        <TextBlock Text="1"/>
                                    </Border>
                                    <TextBlock Text="Connect" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="Install modules, connect to Teams &amp; Graph"
                                         FontSize="12" Opacity="0.7" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <fi:SymbolIcon Grid.Column="1" Symbol="ChevronRight" FontSize="14" Opacity="0.35"
                                       VerticalAlignment="Center" Margin="6,0"/>
                        <!-- Step 2 -->
                        <Border Grid.Column="2" Classes="card interactive" Padding="16">
                            <StackPanel Spacing="10">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Border Classes="step-badge">
                                        <TextBlock Text="2"/>
                                    </Border>
                                    <TextBlock Text="Configure" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="Set variables, domains, time zones, holidays"
                                         FontSize="12" Opacity="0.7" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <fi:SymbolIcon Grid.Column="3" Symbol="ChevronRight" FontSize="14" Opacity="0.35"
                                       VerticalAlignment="Center" Margin="6,0"/>
                        <!-- Step 3 -->
                        <Border Grid.Column="4" Classes="card interactive" Padding="16">
                            <StackPanel Spacing="10">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Border Classes="step-badge">
                                        <TextBlock Text="3"/>
                                    </Border>
                                    <TextBlock Text="Build" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="Create groups, queues, auto attendants"
                                         FontSize="12" Opacity="0.7" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <fi:SymbolIcon Grid.Column="5" Symbol="ChevronRight" FontSize="14" Opacity="0.35"
                                       VerticalAlignment="Center" Margin="6,0"/>
                        <!-- Step 4 -->
                        <Border Grid.Column="6" Classes="card interactive" Padding="16">
                            <StackPanel Spacing="10">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Border Classes="step-badge">
                                        <TextBlock Text="4"/>
                                    </Border>
                                    <TextBlock Text="Export" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="Generate documentation &amp; scripts"
                                         FontSize="12" Opacity="0.7" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>